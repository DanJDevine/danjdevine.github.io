@article{Jennings2021,
  abbr = {JEPP},
	title = {How trust, mistrust and distrust shape the governance of the {COVID}-19 crisis},
	volume = {28},
	issn = {1350-1763},
	url = {https://www.proquest.com/scholarly-journals/how-trust-mistrust-distrust-shape-governance/docview/2550962584/se-2?accountid=13042 http://oxfordsfx.hosted.exlibrisgroup.com/oxford?url_ver=Z39.88-2004&rft_val_fmt=info:ofi/fmt:kev:mtx:journal&genre=article&sid=ProQ:ProQ%3Aibss&atitle=How+trust%2C+mistrust+and+distrust+shape+the+governance+of+the+COVID-19+crisis&title=Journal+of+European+Public+Policy&issn=13501763&date=2021-08-01&volume=28&issue=8&spage=1174&au=Jennings%2C+Will%3BStoker%2C+Gerry%3BValgar%C3%B0sson%2C+Viktor%3BDevine%2C+Daniel%3BGaskell%2C+Jennifer&isbn=&jtitle=Journal+of+European+Public+Policy&btitle=&rft_id=info:eric/&rft_id=info:doi/10.1080%2F13501763.2021.1942151},
	doi = {http://dx.doi.org/10.1080/13501763.2021.1942151},
	abstract = {It is commonplace to claim that trust is essential to effective governance in many contexts, including that of a public health crisis such as the {COVID}-19 pandemic. We argue that trust is better understood as a family of concepts – trust, mistrust and distrust – and each of these may have different implications for the governance of {COVID}-19. Drawing on original measures tested through nationally representative surveys conducted in Australia, Italy, the {UK} and the {USA} between May and June 2020, we explore how these distinct types of trust are associated with citizens’ perceptions of the threat posed by {COVID}-19, and their behavioural responses to it. We show how public policy dynamics around the {COVID}-19 crisis are driven by each of the trust family members and that policymakers might gain more from promoting an information-seeking and mistrusting society, rather than a trusting one.},
	pages = {1174--1196},
	number = {8},
	journal = {Journal of European Public Policy},
	author = {Jennings, Will and Stoker, Gerry and Valgarðsson, Viktor and Devine, Daniel and Gaskell, Jennifer},
	year = {2021},
	pmid = {2550962584},
	keywords = {Coronaviruses, {COVID}-19, Pandemics, Public health, Trust, Crises, mistrust, Policy making, Behavioural responses, crisis, distrust, Families \& family life, governance, Governance, Information seeking, Political trust, Public Administration, Public policy, Relatives},
	file = {Jennings et al_2021_How trust, mistrust and distrust shape the governance of the COVID-19 crisis.pdf:/Users/danieldevine/Zotero/storage/8SBF3PBV/Jennings et al_2021_How trust, mistrust and distrust shape the governance of the COVID-19 crisis.pdf:application/pdf},
}

