	title = {Managing as a minister: How personal style and gender norms affect leadership in government},
	html = {https://www.instituteforgovernment.org.uk/sites/default/files/publications/managing-as-a-minister.pdf}, 
	journal = {Institute for Government},
	abstract = {Using the unique archive of the Institute for Government’s Ministers Reflect interviews,1 this paper examines how ministers approach their management role and reflect on their relationship with the civil service. We looked at more than 100 interviews with former ministers in the archive to identify patterns in how ministers think about and adapt to the challenges of managing their offices and departments.},
